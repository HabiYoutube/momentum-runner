  "authors": [
    "HabiYoutube"
  ],
  "contact": {
    "homepage": "https://github.com/HabiYoutube/momentum-runner",
    "sources": "https://github.com/HabiYoutube/momentum-runner"
  },
  "license": "MIT",
  "icon": "assets/momentumrunner/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.habioutube.momentumrunner.MomentumRunner"
    ]
  },
  "mixins": [
    "momentumrunner.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.21",
    "java": ">=21"
  }
